# fly.toml — Fly.io app config. flyctl reads this on every `fly deploy`.
# Docs: https://fly.io/docs/reference/configuration/

app             = "sonatoday"
primary_region  = "bom"           # Mumbai — closest to Ahmedabad

[build]
  dockerfile = "Dockerfile"

[env]
  DATABASE_PATH = "/data/goldrates.db"

# ── HTTP service ──────────────────────────────────────────────
[http_service]
  internal_port       = 8080
  force_https         = true
  auto_stop_machines  = "off"     # free tier supports 3 always-on shared-cpu-1x VMs
  auto_start_machines = true
  min_machines_running = 1
  processes           = ["app"]

  [http_service.concurrency]
    type       = "requests"
    soft_limit = 100
    hard_limit = 200

# ── Persistent volume for SQLite + uploads ────────────────────
# Create once with:  fly volumes create sonatoday_data --region bom --size 1
[mounts]
  source      = "sonatoday_data"
  destination = "/data"

# ── VM size (free tier limit: 3 × shared-cpu-1x with 256MB) ───
[[vm]]
  cpu_kind = "shared"
  cpus     = 1
  memory   = "256mb"               # tightest free-tier-safe size; bump later if you OOM
