# Copy this file to backend/.env and fill in real values.
# The real .env is gitignored — never commit it.

# Gmail (use a Gmail App Password, not your regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Server
PORT=4000

# Public site URL — used in alert / confirmation emails
SITE_URL=http://localhost:4000

# GoldAPI.io key — sign up at https://www.goldapi.io/
GOLDAPI_KEY=your-goldapi-key

# Secret used to sign JWTs for jeweller logins
JWT_SECRET=change-me-to-a-long-random-string

# Database path (defaults to ./goldrates.db relative to backend/)
DATABASE_URL=./goldrates.db
